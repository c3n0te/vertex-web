package modules

import (
	"fmt"
	"vertex/api"
	"vertex/ui/components/badge"
	"vertex/ui/components/button"
	"vertex/ui/components/card"
)

templ StationsDash(stns []api.Station) {
	<div hx-get="/dashboard/stations/refresh" hx-trigger="every 5s" hx-swap="outerHTML" class="grid grid-cols-2 sm:grid-cols-3 p-4 gap-4 items-center">
		for _, stn := range stns {
			<div>
				@card.Card() {
					@card.Header() {
						@card.Title() {
							{ stn.StnName }
						}
						if stn.Status == "online" {
							@badge.Badge(badge.Props{
								Class: "bg-green-500",
							}) {
								Online
							}
						} else {
							@badge.Badge(badge.Props{
								Class: "bg-red-500",
							}) {
								Offline
							}
						}
					}
					@card.Content() {
					}
					@card.Footer() {
						@button.Button(button.Props{
							Href: fmt.Sprintf("/dashboard/stations/%v", stn.StnName),
						}) {
							Info
						}
					}
				}
			</div>
		}
	</div>
}

templ SatellitesDash(sats []api.Satellite) {
	<div hx-get="/dashboard/satellites/refresh" hx-trigger="every 5s" hx-swap="outerHTML" class="grid grid-cols-2 sm:grid-cols-3 p-4 gap-4 items-center">
		for _, sat := range sats {
			<div>
				@card.Card() {
					@card.Header() {
						@card.Title() {
							{ sat.NoradID }
						}
						@card.Description() {
							{ sat.SatName }
						}
						if sat.Status == "online" {
							@badge.Badge(badge.Props{
								Class: "bg-green-500",
							}) {
								Online
							}
						} else {
							@badge.Badge(badge.Props{
								Class: "bg-red-500",
							}) {
								Offline
							}
						}
					}
					@card.Content() {
					}
					@card.Footer() {
						@button.Button(button.Props{
							Href: fmt.Sprintf("/dashboard/satellites/%v", sat.NoradID),
						}) {
							Info
						}
					}
				}
			</div>
		}
	</div>
}
